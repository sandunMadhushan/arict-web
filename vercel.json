{
  "rewrites": [
    { "source": "/api/members/:id", "destination": "/api/members/[id]" },
    { "source": "/api/events/:id", "destination": "/api/events/[id]" },
    { "source": "/api/blogs/:id", "destination": "/api/blogs/[id]" },
    { "source": "/api/notices/:id", "destination": "/api/notices/[id]" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "Authorization, Accept, Content-Type" }
      ]
    }
  ]
}
